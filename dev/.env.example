DATABASE_URL=mongodb://127.0.0.1/payload-plugin-template
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Optional: restrict the Backups dashboard to users with specific role slugs.
# Comma-separated, case-insensitive. Use `*` to allow any authenticated user.
# Leave unset to fall back to the default (admin role, or all users when the
# users collection has no `roles` field).
# PAYLOAD_BACKUP_ALLOWED_ROLES=admin,superadmin
